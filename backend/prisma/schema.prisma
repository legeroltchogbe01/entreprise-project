datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  binaryTargets   = ["native", "debian-openssl-1.1.x"]
}

enum KYCStatus {
  PENDING
  APPROVED
  REJECTED
  DEACTIVATED
}

enum OrderStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RequestStatus {
  SUBMITTED
  QUOTED
  APPROVED
  REJECTED
}

model Company {
  id                    String           @id @default(uuid())
  denomination_sociale  String
  rccm_number           String
  ifu_number            String
  phone                 String
  email                 String           @unique
  city                  String
  district              String
  house                 String
  square                String
  company_ifu_pdf       String?
  company_rccm_pdf      String?

  // Gérant
  manager_name          String
  manager_rccm          String?
  manager_ifu           String
  manager_phone         String
  manager_email         String
  manager_city          String
  manager_district      String
  manager_house         String
  manager_square        String
  manager_cip_pdf       String
  manager_selfie        String
  manager_ifu_pdf       String?

  // Avaliseur / Garant
  guarantor_name        String
  guarantor_rccm        String?
  guarantor_ifu         String
  guarantor_phone       String
  guarantor_email       String
  guarantor_city        String
  guarantor_district    String
  guarantor_house       String
  guarantor_square      String
  guarantor_cip_pdf     String
  guarantor_selfie      String
  guarantor_ifu_pdf     String?

  kyc_status            KYCStatus        @default(PENDING)
  activated_at          DateTime?
  password              String?
  otp_code              String?
  otp_expires_at        DateTime?
  created_at            DateTime         @default(now())
  wallet                Wallet?
  orders                Order[]
  special_requests      SpecialRequest[]
  profile_update_requests ProfileUpdateRequest[]
}

model Wallet {
  id               String    @id @default(uuid())
  company_id       String    @unique
  company          Company   @relation(fields: [company_id], references: [id], onDelete: Cascade)
  acompte_initial  Decimal   @default(0) @db.Decimal(15, 2)
  acompte_restant  Decimal   @default(0) @db.Decimal(15, 2)
  credit_initial   Decimal   @default(0) @db.Decimal(15, 2)
  credit_utilise   Decimal   @default(0) @db.Decimal(15, 2)
  activated_at     DateTime?
}

model Product {
  id          String      @id @default(uuid())
  name        String
  description String
  price       Decimal     @db.Decimal(15, 2)
  image_url   String
  category    String?
  custom_data Json?
  created_at  DateTime    @default(now())
  order_items OrderItem[]
}

model ProductField {
  id         String   @id @default(uuid())
  key        String   @unique
  label      String
  type       String   // e.g. 'text' | 'number' | 'select' | 'boolean'
  options    Json?    // optional array of options for selects
  ord        Int      @default(0)
  created_at DateTime @default(now())
}

model Category {
  id         String   @id @default(uuid())
  name       String   @unique
  image_url  String?
  created_at DateTime @default(now())
}

model SystemSetting {
  key   String @id
  value String
}

model Order {
  id               String      @id @default(uuid())
  company_id       String
  company          Company     @relation(fields: [company_id], references: [id], onDelete: Cascade)
  order_number     String      @unique
  total_amount     Decimal     @db.Decimal(15, 2)
  payment_schedule Json
  status           OrderStatus @default(PENDING)
  created_at       DateTime    @default(now())
  order_items      OrderItem[]
}

model OrderItem {
  id         String   @id @default(uuid())
  order_id   String
  order      Order    @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product_id String
  product    Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  quantity   Int
  price      Decimal  @db.Decimal(15, 2)
  motif      String?
}

model SpecialRequest {
  id              String        @id @default(uuid())
  company_id      String
  company         Company       @relation(fields: [company_id], references: [id], onDelete: Cascade)
  description     String
  quantity        Int
  image_url       String?
  estimated_price Decimal?      @db.Decimal(15, 2)
  status          RequestStatus @default(SUBMITTED)
  quote_items     Json?
  quote_notes     String?
  contract_content String?
  created_at      DateTime      @default(now())
}

enum ProfileUpdateStatus {
  PENDING
  APPROVED
  REJECTED
}

model ProfileUpdateRequest {
  id          String              @id @default(uuid())
  company_id  String
  company     Company             @relation(fields: [company_id], references: [id], onDelete: Cascade)
  changes     Json                // JSON object with the proposed field changes
  status      ProfileUpdateStatus @default(PENDING)
  admin_note  String?             // Optional note from admin when rejecting/approving
  created_at  DateTime            @default(now())
  updated_at  DateTime            @updatedAt
}
